DATABASE_URL="postgresql://domainhunter:domainhunter_local@localhost:5432/domainhunter?schema=public"
HOST="127.0.0.1"
PORT="4000"
LOG_LEVEL="info"
DOMAIN_HISTORY_PAGE_SIZE="50"
DOMAIN_HISTORY_MAX_PAGE_SIZE="200"
ENABLE_GITHUB_CONNECTOR="true"
ENABLE_WIKIDATA_CONNECTOR="true"
GITHUB_TOKEN=""
CONNECTOR_TIMEOUT_MS="12000"
CONNECTOR_MAX_ATTEMPTS="3"
CONNECTOR_CACHE_TTL_SECONDS="86400"
GITHUB_CONNECTOR_INTERVAL_MS="450"
WIKIDATA_CONNECTOR_INTERVAL_MS="350"
GITHUB_RESULTS_PER_QUERY="5"
WIKIDATA_RESULTS_PER_QUERY="10"
DISCOVERY_MEANINGS_PER_SCAN="5"
DISCOVERY_QUERIES_PER_MEANING="5"
