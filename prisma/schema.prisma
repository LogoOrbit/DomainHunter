generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum SearchStatus {
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum ScanStatus {
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum ContactType {
  BUSINESS_EMAIL
  SALES_EMAIL
  SUPPORT_EMAIL
  PHONE
  FOUNDER
  CEO
  DECISION_MAKER
}

enum ConnectorLogStatus {
  STARTED
  SUCCEEDED
  RETRYING
  FAILED
  SKIPPED
}

enum QueueStatus {
  QUEUED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  HIGH_PRIORITY_BUYER
  SCORE_INCREASE
  NEW_EXECUTIVE
  FUNDING_EVENT
  REBRAND
  COMPANY_CHANGE
  SCAN_COMPLETED
  SCAN_FAILED
}

enum LeadStatus {
  NEW
  RESEARCHING
  QUALIFIED
  HIGH_PRIORITY
  CONTACT_PLANNED
  CONTACTED
  FOLLOW_UP_SCHEDULED
  NEGOTIATING
  OFFER_SENT
  NOT_INTERESTED
  SOLD
  ARCHIVED
}

enum MonitoringStatus {
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model Project {
  id          String         @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  searches    DomainSearch[]

  @@index([createdAt])
  @@map("projects")
}

model Domain {
  id            String          @id @default(cuid())
  asciiName     String          @unique @map("ascii_name")
  displayName   String          @map("display_name")
  label         String
  tld           String
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  searches      DomainSearch[]
  analysis      DomainAnalysis?
  scanJobs      ScanJob[]
  companyScores CompanyScore[]

  @@index([label])
  @@index([tld])
  @@map("domains")
}

model DomainSearch {
  id          String       @id @default(cuid())
  projectId   String?      @map("project_id")
  domainId    String       @map("domain_id")
  status      SearchStatus @default(QUEUED)
  startedAt   DateTime?    @map("started_at")
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  domain      Domain       @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([domainId, status])
  @@index([status, createdAt])
  @@map("domain_searches")
}

model DomainAnalysis {
  id                    String            @id @default(cuid())
  domainId              String            @unique @map("domain_id")
  characterCount        Int               @map("character_count")
  wordCount             Int               @map("word_count")
  hyphenCount           Int               @map("hyphen_count")
  numberCount           Int               @map("number_count")
  letterCount           Int               @map("letter_count")
  pronounceabilityScore Int               @map("pronounceability_score")
  memorabilityScore     Int               @map("memorability_score")
  brandabilityScore     Int               @map("brandability_score")
  lengthScore           Int               @map("length_score")
  seoFriendliness       Int               @map("seo_friendliness")
  commercialPotential   Int               @map("commercial_potential")
  premiumScore          Int               @map("premium_score")
  globalUsability       Int               @map("global_usability")
  startupFriendliness   Int               @map("startup_friendliness")
  strengths             String[]
  weaknesses            String[]
  opportunities         String[]
  risks                 String[]
  idealBuyerProfile     String            @map("ideal_buyer_profile")
  globalMarketSummary   String            @map("global_market_summary")
  analyzedAt            DateTime          @default(now()) @map("analyzed_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  domain                Domain            @relation(fields: [domainId], references: [id], onDelete: Cascade)
  semanticMeanings      SemanticMeaning[]

  @@index([premiumScore])
  @@index([commercialPotential])
  @@index([analyzedAt])
  @@map("domain_analysis")
}

model SemanticMeaning {
  id          String             @id @default(cuid())
  analysisId  String             @map("analysis_id")
  phrase      String
  confidence  Float
  category    String
  explanation String
  rank        Int
  createdAt   DateTime           @default(now()) @map("created_at")
  analysis    DomainAnalysis     @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  industries  SemanticIndustry[]
  useCases    UseCase[]

  @@unique([analysisId, phrase])
  @@index([analysisId, rank])
  @@map("semantic_meanings")
}

model Industry {
  id        String             @id @default(cuid())
  slug      String             @unique
  name      String
  category  String
  createdAt DateTime           @default(now()) @map("created_at")
  meanings  SemanticIndustry[]
  companies CompanyIndustry[]

  @@index([name])
  @@map("industries")
}

model SemanticIndustry {
  semanticMeaningId String          @map("semantic_meaning_id")
  industryId        String          @map("industry_id")
  relevance         Int
  rank              Int
  semanticMeaning   SemanticMeaning @relation(fields: [semanticMeaningId], references: [id], onDelete: Cascade)
  industry          Industry        @relation(fields: [industryId], references: [id], onDelete: Restrict)

  @@id([semanticMeaningId, industryId])
  @@index([industryId])
  @@index([semanticMeaningId, rank])
  @@map("semantic_industries")
}

model UseCase {
  id                String          @id @default(cuid())
  semanticMeaningId String          @map("semantic_meaning_id")
  title             String
  description       String
  relevance         Int
  rank              Int
  createdAt         DateTime        @default(now()) @map("created_at")
  semanticMeaning   SemanticMeaning @relation(fields: [semanticMeaningId], references: [id], onDelete: Cascade)

  @@unique([semanticMeaningId, title])
  @@index([semanticMeaningId, rank])
  @@map("use_cases")
}

model Company {
  id               String            @id @default(cuid())
  dedupeKey        String            @unique @map("dedupe_key")
  normalizedName   String            @map("normalized_name")
  name             String
  website          String?
  officialDomain   String?           @map("official_domain")
  description      String?
  country          String?
  state            String?
  city             String?
  headquarters     String?
  linkedinUrl      String?           @map("linkedin_url")
  contactPage      String?           @map("contact_page")
  companySize      String?           @map("company_size")
  fundingStage     String?           @map("funding_stage")
  latestFunding    String?           @map("latest_funding")
  bookmarked       Boolean           @default(false)
  notes            String?
  firstCollectedAt DateTime          @default(now()) @map("first_collected_at")
  lastCollectedAt  DateTime          @default(now()) @map("last_collected_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  contacts         CompanyContact[]
  sources          CompanySource[]
  scores           CompanyScore[]
  industries       CompanyIndustry[]
  keywords         CompanyKeyword[]
  history          CompanyHistory[]
  scanResults      ScanResult[]

  @@index([normalizedName])
  @@index([officialDomain])
  @@index([country])
  @@index([companySize])
  @@index([fundingStage])
  @@map("companies")
}

model CompanyContact {
  id          String      @id @default(cuid())
  companyId   String      @map("company_id")
  type        ContactType
  name        String?
  title       String?
  value       String?
  sourceUrl   String      @map("source_url")
  collectedAt DateTime    @default(now()) @map("collected_at")
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type, value, sourceUrl])
  @@index([companyId, type])
  @@map("company_contacts")
}

model CompanySource {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  connectorId  String   @map("connector_id")
  sourceUrl    String   @map("source_url")
  fieldOrigins Json     @map("field_origins")
  collectedAt  DateTime @default(now()) @map("collected_at")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, sourceUrl])
  @@index([connectorId, collectedAt])
  @@map("company_sources")
}

model CompanyScore {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  domainId          String   @map("domain_id")
  buyerScore        Int      @map("buyer_score")
  confidenceScore   Int      @map("confidence_score")
  semanticRelevance Int      @map("semantic_relevance")
  industryMatch     Int      @map("industry_match")
  brandSimilarity   Int      @map("brand_similarity")
  keywordSimilarity Int      @map("keyword_similarity")
  domainSimilarity  Int      @map("domain_similarity")
  companyStrength   Int      @map("company_strength")
  technologyMatch   Int      @map("technology_match")
  businessModelFit  Int      @map("business_model_fit")
  matchReason       String   @map("match_reason")
  scoredAt          DateTime @default(now()) @map("scored_at")
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  domain            Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([companyId, domainId])
  @@index([domainId, buyerScore])
  @@index([domainId, confidenceScore])
  @@map("company_scores")
}

model CompanyIndustry {
  companyId  String   @map("company_id")
  industryId String   @map("industry_id")
  relevance  Int
  sourceUrl  String   @map("source_url")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Restrict)

  @@id([companyId, industryId])
  @@index([industryId])
  @@map("company_industries")
}

model CompanyKeyword {
  id        String  @id @default(cuid())
  companyId String  @map("company_id")
  keyword   String
  relevance Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, keyword])
  @@index([keyword])
  @@map("company_keywords")
}

model CompanyHistory {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  eventType String   @map("event_type")
  details   Json
  createdAt DateTime @default(now()) @map("created_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("company_history")
}

model ScanJob {
  id                   String         @id @default(cuid())
  domainId             String         @map("domain_id")
  status               ScanStatus     @default(QUEUED)
  progress             Int            @default(0)
  totalQueries         Int            @default(0) @map("total_queries")
  processedQueries     Int            @default(0) @map("processed_queries")
  companiesFound       Int            @default(0) @map("companies_found")
  duplicateMerges      Int            @default(0) @map("duplicate_merges")
  estimatedSecondsLeft Int?           @map("estimated_seconds_left")
  queryPlan            Json           @map("query_plan")
  processedQueryKeys   String[]       @map("processed_query_keys")
  connectorStatus      Json           @map("connector_status")
  errors               Json
  requestedAt          DateTime       @default(now()) @map("requested_at")
  startedAt            DateTime?      @map("started_at")
  completedAt          DateTime?      @map("completed_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  domain               Domain         @relation(fields: [domainId], references: [id], onDelete: Cascade)
  results              ScanResult[]
  logs                 ConnectorLog[]

  @@index([domainId, requestedAt])
  @@index([status, requestedAt])
  @@map("scan_jobs")
}

model ScanResult {
  id          String   @id @default(cuid())
  scanJobId   String   @map("scan_job_id")
  companyId   String   @map("company_id")
  connectorId String   @map("connector_id")
  query       String
  createdAt   DateTime @default(now()) @map("created_at")
  scanJob     ScanJob  @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([scanJobId, companyId, connectorId, query])
  @@index([scanJobId, createdAt])
  @@map("scan_results")
}

model ConnectorLog {
  id               String             @id @default(cuid())
  scanJobId        String             @map("scan_job_id")
  connectorId      String             @map("connector_id")
  query            String?
  status           ConnectorLogStatus
  attempt          Int                @default(1)
  durationMs       Int?               @map("duration_ms")
  recordsCollected Int?               @map("records_collected")
  errorMessage     String?            @map("error_message")
  apiUsage         Json?              @map("api_usage")
  createdAt        DateTime           @default(now()) @map("created_at")
  scanJob          ScanJob            @relation(fields: [scanJobId], references: [id], onDelete: Cascade)

  @@index([scanJobId, connectorId, createdAt])
  @@map("connector_logs")
}

model ConnectorCache {
  id          String   @id @default(cuid())
  connectorId String   @map("connector_id")
  queryKey    String   @map("query_key")
  records     Json
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([connectorId, queryKey])
  @@index([expiresAt])
  @@map("connector_cache")
}

model SavedLeadFilter {
  id        String   @id @default(cuid())
  domainId  String?  @map("domain_id")
  name      String
  filters   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([domainId, createdAt])
  @@map("saved_lead_filters")
}

model Valuation {
  id                 String   @id @default(cuid())
  domainId           String   @unique @map("domain_id")
  inputHash          String   @map("input_hash")
  lowEstimate        Int      @map("low_estimate")
  fairEstimate       Int      @map("fair_estimate")
  premiumEstimate    Int      @map("premium_estimate")
  investorEstimate   Int      @map("investor_estimate")
  endUserEstimate    Int      @map("end_user_estimate")
  confidence         Int
  components         Json
  comparables        Json
  verifiedPublicData Json     @map("verified_public_data")
  aiEstimate         Json     @map("ai_estimate")
  explanation        Json
  opportunityReport  Json     @map("opportunity_report")
  generatedAt        DateTime @default(now()) @map("generated_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([inputHash])
  @@map("valuations")
}

model PricingHistory {
  id              String   @id @default(cuid())
  domainId        String   @map("domain_id")
  valuationId     String   @map("valuation_id")
  lowEstimate     Int      @map("low_estimate")
  fairEstimate    Int      @map("fair_estimate")
  premiumEstimate Int      @map("premium_estimate")
  recordedAt      DateTime @default(now()) @map("recorded_at")

  @@index([domainId, recordedAt])
  @@map("pricing_history")
}

model BuyerRanking {
  id                     String   @id @default(cuid())
  domainId               String   @map("domain_id")
  companyId              String   @map("company_id")
  inputHash              String   @map("input_hash")
  rank                   Int
  segment                String
  buyerFit               Int      @map("buyer_fit")
  strategicRelevance     Int      @map("strategic_relevance")
  businessModelFit       Int      @map("business_model_fit")
  semanticAlignment      Int      @map("semantic_alignment")
  commercialPotential    Int      @map("commercial_potential")
  acquisitionProbability Int      @map("acquisition_probability")
  outreachPriority       Int      @map("outreach_priority")
  explanation            Json
  rankedAt               DateTime @default(now()) @map("ranked_at")

  @@unique([domainId, companyId])
  @@index([domainId, rank])
  @@map("buyer_rankings")
}

model BuyerExplanation {
  id             String   @id @default(cuid())
  rankingId      String   @unique @map("ranking_id")
  reasons        String[]
  risks          String[]
  suggestedAngle String   @map("suggested_angle")
  scoreDetails   Json     @map("score_details")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("buyer_explanations")
}

model OutreachTemplate {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  channel      String
  subject      String?
  body         String
  placeholders Json
  isSystem     Boolean  @default(true) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("outreach_templates")
}

model GeneratedMessage {
  id             String   @id @default(cuid())
  domainId       String   @map("domain_id")
  companyId      String?  @map("company_id")
  templateId     String   @map("template_id")
  inputHash      String   @map("input_hash")
  subject        String?
  body           String
  customizations Json
  status         String   @default("DRAFT")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([domainId, createdAt])
  @@map("generated_messages")
}

model NegotiationPlan {
  id               String   @id @default(cuid())
  domainId         String   @unique @map("domain_id")
  valuationId      String   @map("valuation_id")
  inputHash        String   @map("input_hash")
  openingPrice     Int      @map("opening_price")
  targetPrice      Int      @map("target_price")
  floorPrice       Int      @map("floor_price")
  strategy         Json
  objectionScripts Json     @map("objection_scripts")
  generatedAt      DateTime @default(now()) @map("generated_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("negotiation_plans")
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  domainId  String   @map("domain_id")
  inputHash String   @map("input_hash")
  metrics   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([domainId, inputHash])
  @@index([domainId, createdAt])
  @@map("analytics_snapshots")
}

model Connector {
  id               String    @id
  name             String
  enabled          Boolean   @default(true)
  paused           Boolean   @default(false)
  configuration    Json
  totalRequests    Int       @default(0) @map("total_requests")
  successfulRuns   Int       @default(0) @map("successful_runs")
  failedRuns       Int       @default(0) @map("failed_runs")
  recordsCollected Int       @default(0) @map("records_collected")
  averageLatencyMs Int       @default(0) @map("average_latency_ms")
  lastRunAt        DateTime? @map("last_run_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("connectors")
}

model ConnectorHealth {
  id          String   @id @default(cuid())
  connectorId String   @map("connector_id")
  healthy     Boolean
  latencyMs   Int      @map("latency_ms")
  message     String?
  checkedAt   DateTime @default(now()) @map("checked_at")

  @@index([connectorId, checkedAt])
  @@map("connector_health")
}

model ScanTask {
  id          String      @id @default(cuid())
  scanJobId   String      @map("scan_job_id")
  connectorId String      @map("connector_id")
  query       String
  status      QueueStatus @default(QUEUED)
  attempts    Int         @default(0)
  availableAt DateTime    @default(now()) @map("available_at")
  startedAt   DateTime?   @map("started_at")
  completedAt DateTime?   @map("completed_at")
  error       String?

  @@unique([scanJobId, connectorId, query])
  @@index([status, availableAt])
  @@map("scan_tasks")
}

model ScanHistory {
  id        String   @id @default(cuid())
  scanJobId String   @map("scan_job_id")
  event     String
  details   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([scanJobId, createdAt])
  @@map("scan_history")
}

model ScanProgress {
  id               String   @id @default(cuid())
  scanJobId        String   @map("scan_job_id")
  progress         Int
  companiesFound   Int      @map("companies_found")
  companiesUpdated Int      @map("companies_updated")
  recordedAt       DateTime @default(now()) @map("recorded_at")

  @@index([scanJobId, recordedAt])
  @@map("scan_progress")
}

model CompanyChange {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  scanJobId     String?  @map("scan_job_id")
  field         String
  previousValue String?  @map("previous_value")
  currentValue  String?  @map("current_value")
  significance  Int      @default(50)
  detectedAt    DateTime @default(now()) @map("detected_at")

  @@index([companyId, detectedAt])
  @@map("company_changes")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  domainId  String?          @map("domain_id")
  companyId String?          @map("company_id")
  title     String
  message   String
  data      Json
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([readAt, createdAt])
  @@map("notifications")
}

model JobQueue {
  id          String      @id @default(cuid())
  scanJobId   String      @unique @map("scan_job_id")
  status      QueueStatus @default(QUEUED)
  priority    Int         @default(50)
  attempts    Int         @default(0)
  maxAttempts Int         @default(4) @map("max_attempts")
  availableAt DateTime    @default(now()) @map("available_at")
  claimedBy   String?     @map("claimed_by")
  claimedAt   DateTime?   @map("claimed_at")
  lastError   String?     @map("last_error")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([status, priority, availableAt])
  @@map("job_queue")
}

model WorkerStatus {
  id            String   @id
  status        String
  currentJobId  String?  @map("current_job_id")
  jobsCompleted Int      @default(0) @map("jobs_completed")
  jobsFailed    Int      @default(0) @map("jobs_failed")
  lastHeartbeat DateTime @map("last_heartbeat")
  startedAt     DateTime @default(now()) @map("started_at")
  metadata      Json

  @@index([lastHeartbeat])
  @@map("worker_status")
}

model ScanSchedule {
  id        String    @id @default(cuid())
  domainId  String    @map("domain_id")
  frequency String
  cron      String?
  priority  Int       @default(50)
  enabled   Boolean   @default(true)
  nextRunAt DateTime  @map("next_run_at")
  lastRunAt DateTime? @map("last_run_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([enabled, nextRunAt])
  @@map("scan_schedules")
}

model ProjectDomain {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  domainId  String   @map("domain_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([projectId, domainId])
  @@index([domainId])
  @@map("project_domains")
}

model ProjectCompany {
  id              String     @id @default(cuid())
  projectId       String     @map("project_id")
  companyId       String     @map("company_id")
  status          LeadStatus @default(NEW)
  priority        Int        @default(50)
  favorite        Boolean    @default(false)
  manualScore     Int?       @map("manual_score")
  privateComments String?    @map("private_comments")
  reminderDate    DateTime?  @map("reminder_date")
  lastReviewedAt  DateTime?  @map("last_reviewed_at")
  lastContactedAt DateTime?  @map("last_contacted_at")
  followUpAt      DateTime?  @map("follow_up_at")
  archivedAt      DateTime?  @map("archived_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@unique([projectId, companyId])
  @@index([projectId, status, priority])
  @@map("project_companies")
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

